generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       BigInt                    @id @default(autoincrement())
  username                 String                    @unique @db.VarChar(20)
  passwordHash             String                    @map("password_hash") @db.VarChar(255)
  // Pure match-count now (see 20260708100000_... migration note) — no
  // longer +1 on ball creation, only +1 per side on every completed match.
  totalAcquiredCount       Int                       @default(0) @map("total_acquired_count")
  // Lifetime wax-break count, +1 on every successful POST /:ownedId/break
  // regardless of which ball. No historical backfill possible (no event log
  // existed before this column).
  totalBreakCount          Int                       @default(0) @map("total_break_count")
  // Cumulative distinct partners ever matched with (deduped) — maintained
  // as a counter rather than computed live so the leaderboard is a plain
  // ORDER BY. See createOrRefillMatchedOwnedWakppuball's isNewPartner.
  distinctMatchedUserCount Int                       @default(0) @map("distinct_matched_user_count")
  createdAt                DateTime                  @default(now()) @map("created_at")
  createdModels            WakppuballModel[]         @relation("CreatedModels")
  ownedWakppuballs         UserWakppuball[]          @relation("OwnedWakppuballs")
  acquiredSources          UserWakppuball[]          @relation("AcquiredFromUser")
  matchesAsA               MatchHistory[]            @relation("MatchUserA")
  matchesAsB               MatchHistory[]            @relation("MatchUserB")
  locationVerificationLogs LocationVerificationLog[]

  @@map("users")
}

model WakppuballModel {
  id                 BigInt             @id @default(autoincrement())
  creatorUserId      BigInt?            @map("creator_user_id")
  name               String?            @db.VarChar(50)
  modelUrl           String?            @map("model_url")
  thumbnailUrl       String?            @map("thumbnail_url")
  customizationJson  Json?              @map("customization_json")
  fractureJson       Json?              @map("fracture_json")
  defaultBreakCount  Int                @default(3) @map("default_break_count")
  createdAt          DateTime           @default(now()) @map("created_at")
  creator            User?              @relation("CreatedModels", fields: [creatorUserId], references: [id])
  owners             UserWakppuball[]

  @@map("wakppuball_models")
}

model UserWakppuball {
  id                   BigInt            @id @default(autoincrement())
  ownerUserId          BigInt            @map("owner_user_id")
  wakppuballModelId    BigInt            @map("wakppuball_model_id")
  acquiredType         AcquiredType       @default(CREATED) @map("acquired_type")
  acquiredFromUserId   BigInt?           @map("acquired_from_user_id")
  isMain               Boolean           @default(false) @map("is_main")
  remainingBreakCount  Int                    @default(3) @map("remaining_break_count")
  status               OwnedWakppuballStatus  @default(ACTIVE)
  // True only when the match/refill that most recently produced this row's
  // current state had both sides verified inside the campus geofence — not
  // sticky, overwritten on every refill. Purely cosmetic (a badge), never
  // gates anything. See matching.routes.ts.
  isCampusMatch        Boolean                @default(false) @map("is_campus_match")
  acquiredAt           DateTime               @default(now()) @map("acquired_at")
  consumedAt           DateTime?              @map("consumed_at")
  owner                User                   @relation("OwnedWakppuballs", fields: [ownerUserId], references: [id])
  model                WakppuballModel        @relation(fields: [wakppuballModelId], references: [id])
  acquiredFromUser     User?                  @relation("AcquiredFromUser", fields: [acquiredFromUserId], references: [id])
  sentByA              MatchHistory[]         @relation("MatchSentByA")
  sentByB              MatchHistory[]         @relation("MatchSentByB")

  @@unique([ownerUserId, acquiredFromUserId])
  @@index([ownerUserId, status])
  @@index([ownerUserId, isMain])
  @@map("user_wakppuballs")
}

model MatchHistory {
  id                       BigInt           @id @default(autoincrement())
  userAId                  BigInt           @map("user_a_id")
  userBId                  BigInt           @map("user_b_id")
  userASentWakppuballId    BigInt?          @map("user_a_sent_wakppuball_id")
  userBSentWakppuballId    BigInt?          @map("user_b_sent_wakppuball_id")
  matchedAt                DateTime         @default(now()) @map("matched_at")
  userA                    User             @relation("MatchUserA", fields: [userAId], references: [id])
  userB                    User             @relation("MatchUserB", fields: [userBId], references: [id])
  userASentWakppuball      UserWakppuball?  @relation("MatchSentByA", fields: [userASentWakppuballId], references: [id])
  userBSentWakppuball      UserWakppuball?  @relation("MatchSentByB", fields: [userBSentWakppuballId], references: [id])

  @@map("match_history")
}

model LocationVerificationLog {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  passed    Boolean
  checkedAt DateTime @default(now()) @map("checked_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, checkedAt])
  @@map("location_verification_logs")
}

enum AcquiredType {
  CREATED
  MATCHED
}

enum OwnedWakppuballStatus {
  ACTIVE
  CONSUMED
}

model MatchingQueueEntry {
  id                    BigInt              @id @default(autoincrement())
  userId                BigInt              @map("user_id")
  wakppuballOwnedId     BigInt              @map("wakppuball_owned_id")
  status                MatchingQueueStatus @default(WAITING)
  // Was this entry's submitted location inside the campus geofence (false if
  // no coordinates were submitted at all — location is optional now).
  locationVerified      Boolean             @default(false) @map("location_verified")
  matchHistoryId        BigInt?             @map("match_history_id")
  receivedWakppuballId  BigInt?             @map("received_wakppuball_id")
  enteredAt             DateTime            @default(now()) @map("entered_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([userId, status, enteredAt])
  @@index([status, enteredAt])
  @@map("matching_queue_entries")
}

enum MatchingQueueStatus {
  WAITING
  MATCHED
  CANCELLED
}
